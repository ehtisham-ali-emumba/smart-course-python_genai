      "targets": [{ "expr": "container_memory_usage_bytes{name=~\"smartcourse-.*\"} / container_spec_memory_limit_bytes{name=~\"smartcourse-.*\"}", "legendFormat": "{{name}}", "refId": "A" }],
      "title": "Memory Usage vs Limit",
      "type": "timeseries"
