{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [{ "expr": "sum(pg_stat_activity_count{datname=\"smartcourse\"}) by (state)", "legendFormat": "{{state}}", "refId": "A" }],
      "title": "PostgreSQL Active Connections",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [{ "expr": "rate(pg_stat_database_xact_commit{datname=\"smartcourse\"}[5m])", "refId": "A" }],
      "title": "PostgreSQL Transaction Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [{ "expr": "pg_database_size_bytes{datname=\"smartcourse\"}", "refId": "A" }],
      "title": "PostgreSQL Database Size",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "used", "refId": "A" },
        { "expr": "redis_memory_max_bytes", "legendFormat": "max", "refId": "B" }
      ],
      "title": "Redis Memory Used vs Max",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        { "expr": "redis_connected_clients", "legendFormat": "clients", "refId": "A" },
        { "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)", "legendFormat": "hit ratio", "refId": "B" },
        { "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "commands/s", "refId": "C" },
        { "expr": "rate(redis_evicted_keys_total[5m])", "legendFormat": "evictions/s", "refId": "D" }
      ],
      "title": "Redis Health and Throughput",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 7,
      "targets": [{ "expr": "rate(mongodb_op_counters_total[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "MongoDB Operations per Second",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["smartcourse", "databases"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "SmartCourse Databases",
  "uid": "smartcourse-databases",
  "version": 1,
  "weekStart": ""
}
